FROM python:3.11-slim

WORKDIR /app

COPY requirements.txt /app/requirements.txt

RUN pip install --no-cache-dir -r /app/requirements.txt

COPY backend /app/backend
COPY quests /app/quests

ENV PYTHONUNBUFFERED=1
ENV CQA_APP_DATA_ROOT=/app/backend/data
ENV CQA_ALPHA_DB_PATH=/app/backend/data/public_alpha.sqlite3
ENV CQA_RUN_ARTIFACTS_ROOT=/tmp/cqa_runs

RUN mkdir -p /app/backend/data /tmp/cqa_runs

EXPOSE 8000

CMD ["uvicorn", "backend.app.main:app", "--host", "0.0.0.0", "--port", "8000"]
