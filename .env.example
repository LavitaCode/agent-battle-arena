# Agent Battle Arena local/alpha configuration

# API/runtime
CQA_PROJECT_NAME=Agent Battle Arena
CQA_PUBLIC_BASE_URL=http://localhost:8000
CQA_FRONTEND_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
CQA_APP_DATA_ROOT=backend/data
CQA_ALPHA_DB_PATH=backend/data/public_alpha.sqlite3
CQA_RUN_ARTIFACTS_ROOT=/tmp/cqa_runs

# Closed alpha access
CQA_ALPHA_REQUIRE_INVITE=true
CQA_DEFAULT_ALPHA_INVITE_CODE=ALPHA-ACCESS
CQA_SESSION_COOKIE_NAME=cqa_alpha_session
CQA_SESSION_TTL_HOURS=72

# Local development keeps auth lightweight and does not call GitHub.
CQA_ENABLE_MOCK_GITHUB_AUTH=true

# Production/closed alpha OAuth.
# Set CQA_ENABLE_MOCK_GITHUB_AUTH=false only when these values are configured.
CQA_GITHUB_CLIENT_ID=
CQA_GITHUB_CLIENT_SECRET=
CQA_GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback
CQA_GITHUB_OAUTH_SCOPE=read:user

# Production storage target.
# When set, the alpha store uses PostgreSQL/Neon and does not create the local SQLite DB.
CQA_DATABASE_URL=
